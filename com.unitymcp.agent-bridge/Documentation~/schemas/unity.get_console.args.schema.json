{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "unity.get_console args",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "types"
  ],
  "properties": {
    "types": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "error",
          "warning",
          "info"
        ]
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000
    }
  }
}
