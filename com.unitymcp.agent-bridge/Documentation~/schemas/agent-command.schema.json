{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity Agent Bridge command envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "commandId",
    "tool",
    "timeoutMs",
    "createdAt",
    "args"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "commandId": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "args": {
      "type": "object"
    }
  }
}
