{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "unity.read_report args",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportPath"
  ],
  "properties": {
    "reportPath": {
      "type": "string",
      "minLength": 1
    },
    "jsonPointer": {
      "type": "string",
      "default": ""
    },
    "offset": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500,
      "default": 100
    },
    "maxBytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 262144,
      "default": 65536
    }
  }
}
