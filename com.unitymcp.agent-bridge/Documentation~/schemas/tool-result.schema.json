{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Unity Agent Bridge tool result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "commandId",
    "tool",
    "success",
    "status",
    "startedAt",
    "finishedAt",
    "durationMs",
    "summary",
    "errors",
    "warnings",
    "logs",
    "metrics",
    "changedFiles",
    "reportPath"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "commandId": {
      "type": "string",
      "minLength": 1
    },
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "success": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "resuming",
        "success",
        "failed",
        "timeout",
        "blocked",
        "unsupported",
        "invalid_args",
        "exception",
        "cancelled"
      ]
    },
    "startedAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "finishedAt": {
      "type": [
        "string",
        "null"
      ]
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message",
          "file",
          "line",
          "column"
        ],
        "properties": {
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "file": {
            "type": [
              "string",
              "null"
            ]
          },
          "line": {
            "type": "integer"
          },
          "column": {
            "type": "integer"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "level",
          "message",
          "timestamp"
        ],
        "properties": {
          "level": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "metrics": {
      "type": "object"
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reportPath": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "toolError": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "file",
        "line",
        "column"
      ],
      "properties": {
        "code": {
          "type": [
            "string",
            "null"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "file": {
          "type": [
            "string",
            "null"
          ]
        },
        "line": {
          "type": "integer"
        },
        "column": {
          "type": "integer"
        }
      }
    }
  }
}
