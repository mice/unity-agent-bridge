{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "unity.execute_csharp args",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "code"
  ],
  "properties": {
    "code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 65536,
      "description": "AI-generated C# body for private static object __Run(). The Unity tool wraps this body in the fixed Entry.Run JSON wrapper."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 100,
      "maximum": 10000,
      "default": 2000
    }
  }
}
